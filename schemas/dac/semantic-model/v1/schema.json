{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://getbruin.com/schemas/dac/semantic-model/v1",
  "title": "Bruin DAC Semantic Model",
  "type": "object",
  "required": ["name", "source"],
  "properties": {
    "schema": {
      "const": "https://getbruin.com/schemas/dac/semantic-model/v1"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "dimensions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dimension"
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/metric"
      }
    },
    "segments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/segment"
      }
    }
  },
  "patternProperties": {
    "^x-": true
  },
  "additionalProperties": false,
  "$defs": {
    "source": {
      "type": "object",
      "required": ["table"],
      "properties": {
        "table": {
          "type": "string",
          "minLength": 1
        }
      },
      "patternProperties": {
        "^x-": true
      },
      "additionalProperties": false
    },
    "dimension": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "type": {
          "enum": ["string", "number", "boolean", "time"]
        },
        "expression": {
          "type": "string"
        },
        "granularities": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "hidden": {
          "type": "boolean"
        },
        "group": {
          "type": "string"
        }
      },
      "patternProperties": {
        "^x-": true
      },
      "additionalProperties": false
    },
    "metric": {
      "type": "object",
      "required": ["name", "expression"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "expression": {
          "type": "string",
          "minLength": 1
        },
        "filter": {
          "type": "string"
        },
        "hidden": {
          "type": "boolean"
        },
        "group": {
          "type": "string"
        },
        "format": {
          "$ref": "#/$defs/format"
        },
        "window": {
          "$ref": "#/$defs/window"
        }
      },
      "patternProperties": {
        "^x-": true
      },
      "additionalProperties": false
    },
    "format": {
      "type": "object",
      "properties": {
        "type": {
          "enum": ["number", "currency", "percentage", "decimal"]
        },
        "currency": {
          "type": "string"
        },
        "decimals": {
          "type": "integer",
          "minimum": 0
        }
      },
      "patternProperties": {
        "^x-": true
      },
      "additionalProperties": false
    },
    "window": {
      "type": "object",
      "properties": {
        "type": {
          "enum": ["running_total", "lag", "lead", "rank", "percent_of_total"]
        },
        "order_by": {
          "type": "string"
        },
        "partition_by": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "offset": {
          "type": "integer",
          "minimum": 0
        }
      },
      "patternProperties": {
        "^x-": true
      },
      "additionalProperties": false
    },
    "segment": {
      "type": "object",
      "required": ["name", "filter"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "filter": {
          "type": "string",
          "minLength": 1
        }
      },
      "patternProperties": {
        "^x-": true
      },
      "additionalProperties": false
    }
  }
}
