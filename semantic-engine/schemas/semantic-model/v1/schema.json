{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "v1",
  "title": "Bruin Semantic Model",
  "type": "object",
  "required": ["name", "source"],
  "properties": {
    "schema": {
      "comment": "v1 is canonical; the getbruin.com URL is the legacy dac identifier, accepted for backward compatibility.",
      "enum": [
        "v1",
        "https://getbruin.com/schemas/dac/semantic-model/v1"
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "primary_key": {
      "type": "string"
    },
    "joins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/join"
      }
    },
    "dimensions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dimension"
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/metric"
      }
    },
    "segments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/segment"
      }
    }
  },
  "patternProperties": {
    "^x-": true
  },
  "additionalProperties": false,
  "$defs": {
    "source": {
      "type": "object",
      "required": ["table"],
      "properties": {
        "table": {
          "type": "string",
          "minLength": 1
        }
      },
      "patternProperties": {
        "^x-": true
      },
      "additionalProperties": false
    },
    "join": {
      "type": "object",
      "required": ["name", "relationship"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "relationship": {
          "enum": ["one_to_one", "many_to_one", "one_to_many", "many_to_many"]
        },
        "foreign_key": {
          "type": "string"
        },
        "target_key": {
          "type": "string"
        },
        "sql": {
          "type": "string"
        }
      },
      "patternProperties": {
        "^x-": true
      },
      "additionalProperties": false
    },
    "dimension": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "type": {
          "enum": ["string", "number", "boolean", "time"]
        },
        "expression": {
          "type": "string"
        },
        "granularities": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "hidden": {
          "type": "boolean"
        },
        "group": {
          "type": "string"
        }
      },
      "patternProperties": {
        "^x-": true
      },
      "additionalProperties": false
    },
    "metric": {
      "type": "object",
      "required": ["name", "expression"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "expression": {
          "type": "string",
          "minLength": 1
        },
        "filter": {
          "type": "string"
        },
        "hidden": {
          "type": "boolean"
        },
        "group": {
          "type": "string"
        },
        "format": {
          "$ref": "#/$defs/format"
        },
        "window": {
          "$ref": "#/$defs/window"
        }
      },
      "patternProperties": {
        "^x-": true
      },
      "additionalProperties": false
    },
    "format": {
      "type": "object",
      "properties": {
        "type": {
          "enum": ["number", "currency", "percentage", "decimal"]
        },
        "currency": {
          "type": "string"
        },
        "decimals": {
          "type": "integer",
          "minimum": 0
        }
      },
      "patternProperties": {
        "^x-": true
      },
      "additionalProperties": false
    },
    "window": {
      "type": "object",
      "properties": {
        "type": {
          "enum": ["running_total", "lag", "lead", "rank", "percent_of_total"]
        },
        "order_by": {
          "type": "string"
        },
        "partition_by": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "offset": {
          "type": "integer",
          "minimum": 0
        }
      },
      "patternProperties": {
        "^x-": true
      },
      "additionalProperties": false
    },
    "segment": {
      "type": "object",
      "required": ["name", "filter"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "filter": {
          "type": "string",
          "minLength": 1
        }
      },
      "patternProperties": {
        "^x-": true
      },
      "additionalProperties": false
    }
  }
}
