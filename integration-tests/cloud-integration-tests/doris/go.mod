// Separate module so testcontainers-go and the Docker client tree stay out of
// the root module that builds the shipped bruin CLI. Uses a replace to consume
// the local bruin source (for pkg/e2e and the platform code under test).
module github.com/bruin-data/bruin/integration-tests/cloud-integration-tests/doris

go 1.25.0

replace github.com/bruin-data/bruin => ../../../

replace github.com/bruin-data/bruin/semantic-engine => ../../../semantic-engine

require (
	github.com/bruin-data/bruin v0.0.0-00010101000000-000000000000
	github.com/go-sql-driver/mysql v1.9.3
	github.com/moby/moby/api v1.54.1
	github.com/stretchr/testify v1.11.1
	github.com/testcontainers/testcontainers-go v0.42.0
)

