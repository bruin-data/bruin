# Enforce LF line endings in the working tree on every platform. Without this,
# Windows checkouts (core.autocrlf=true) produce CRLF files that corrupt Go
# formatter output — gci/gofumpt insert blank lines throughout CRLF files — and
# create spurious whole-file diffs. All repo blobs are already LF, so this only
# locks in the existing state.
* text=auto eol=lf

# Treat binary files as binary to prevent corruption
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp4 binary
*.webm binary
*.mov binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Specify language for Python files
*.py linguist-language=Python

# Specify language for Go files
*.go linguist-language=Go

# Exclude test files from language statistics
tests/** linguist-vendored
*.test.py linguist-vendored

# Exclude documentation files from language statistics
docs/** linguist-vendored
*.md linguist-vendored

# Exclude internal folder from language statistics
internal/** linguist-vendored

# Exclude pythonsrc folder from language statistics
pythonsrc/** linguist-vendored
